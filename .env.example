# --- Telegram ---
BOT_TOKEN=123456:replace_with_telegram_bot_token
BOT_USERNAME=your_bot_username        # without @, used for referral links

# Public URL of the Mini App frontend (GitHub Pages)
WEBAPP_URL=https://ewgeen239-netizen.github.io/gym-game-bot/

# --- Web server ---
PORT=8080
HOST=0.0.0.0
# Comma-separated origins allowed to call the API (the Pages origin)
ALLOWED_ORIGINS=https://ewgeen239-netizen.github.io

# --- Storage: Google Sheets (leave blank to use local JSON fallback) ---
# Paste the FULL service-account JSON as a single-line value.
GOOGLE_SHEETS_CREDS=
GOOGLE_SHEET_ID=
# Used only when Sheets is not configured:
DATA_FILE=./data/gym-game-bot.json
